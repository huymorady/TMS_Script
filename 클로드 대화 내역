javascript/**
 * 세그먼트 하나에 대해 채팅·배치에서 생성된 결과를 한 번에 조회
 */
function getSegmentWorkState(stringId) {
    const id = normalizeId(stringId);
    
    // 채팅 측
    const session = getSession(id);
    const chatMessages = session.messages || [];
    const lastAi = [...chatMessages].reverse().find(m => m.role === 'ai');
    
    // 배치 측
    const run = batchRun || restoreActiveBatchRun();
    const phase3 = run?.phase3?.parsed?.translations
        ?.find(t => normalizeId(t.id) === id);
    const revision = run?.phase45?.parsed?.revisions
        ?.find(r => normalizeId(r.id) === id);
    
    return {
        id,
        chat: {
            hasSession: chatMessages.length > 0,
            messageCount: chatMessages.length,
            lastTranslation: lastAi?.content || null,
            updatedAt: session.updated || null,
        },
        batch: {
            hasPhase3: !!phase3,
            phase3Text: phase3?.t || null,
            hasRevision: !!revision,
            revisionText: (revision && revision.t !== null) ? revision.t : null,
            groupId: phase3?.gid || null,
            changed: revision?.t !== null && revision?.t !== undefined,
            reasons: revision?.r || [],
        },
        // 최종 후보 (우선순위: revision → phase3 → chat)
        finalCandidate: (revision?.t !== null && revision?.t !== undefined)
            ? revision.t
            : (phase3?.t ?? lastAi?.content ?? null),
    };
}
