javascriptfunction formatPhase12Detail(validation) {
    if (!validation) return '대기';
    if (validation.ok) return 'OK';
    const reasons = [];
    if (validation.coverage && !validation.coverage.ok) {
        const c = validation.coverage;
        if (c.missing.length) reasons.push(`누락 ${c.missing.length}개`);
        if (c.extra.length) reasons.push(`추가 ${c.extra.length}개`);
        if (c.duplicates.length) reasons.push(`중복 ${c.duplicates.length}개`);
    }
    if (validation.invalidGroups?.length) {
        reasons.push(`그룹 스키마 오류 ${validation.invalidGroups.length}개`);
    }
    if (validation.groupsCount === 0) reasons.push('그룹 없음');
    return `주의 필요 (${reasons.join(', ') || 'phase 불일치 등'})`;
}
